# Copy to .env and fill in. Never commit real secrets (design §11).

# --- Store -----------------------------------------------------------------
# v1 backend is Postgres; swap the driver/URL to move to TimescaleDB etc.
DATA_PLANE_STORE_BACKEND=postgres
DATA_PLANE_DATABASE_URL=postgresql://macro:macro@localhost:5432/macro_watcher

# --- Sources ---------------------------------------------------------------
DATA_PLANE_FRED_API_KEY=your_fred_api_key_here
# GDELT needs no key.

# --- Ingestion cadence (seconds) ------------------------------------------
DATA_PLANE_FRED_POLL_INTERVAL=3600
DATA_PLANE_GDELT_POLL_INTERVAL=900
